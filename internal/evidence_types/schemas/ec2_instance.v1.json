{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.sigcomply.io/evidence_types/ec2_instance/v1.json",
  "title": "ec2_instance",
  "version": 1,
  "description": "One AWS EC2 instance, with the exposure flags policies check today.",
  "type": "object",
  "required": ["instance_id", "has_public_ip"],
  "properties": {
    "instance_id":        { "type": "string" },
    "state":              { "type": "string" },
    "instance_type":      { "type": "string" },
    "public_ip_address":  { "type": "string" },
    "private_ip_address": { "type": "string" },
    "vpc_id":             { "type": "string" },
    "has_public_ip":      { "type": "boolean" }
  },
  "additionalProperties": true
}
