{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.sigcomply.io/evidence_types/cloudwatch_log_group/v1.json",
  "title": "cloudwatch_log_group",
  "version": 1,
  "description": "One AWS CloudWatch Logs log group, with retention and encryption flags policies check today.",
  "type": "object",
  "required": ["name", "retention_set"],
  "properties": {
    "name":                 { "type": "string" },
    "arn":                  { "type": "string" },
    "retention_in_days":    { "type": "integer" },
    "retention_set":        { "type": "boolean" },
    "kms_key_id":           { "type": "string" },
    "stored_bytes":         { "type": "integer" },
    "metric_filter_count":  { "type": "integer" }
  },
  "additionalProperties": true
}
