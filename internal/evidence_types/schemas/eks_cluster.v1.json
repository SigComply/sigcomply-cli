{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.sigcomply.io/evidence_types/eks_cluster/v1.json",
  "title": "eks_cluster",
  "version": 1,
  "description": "One AWS EKS cluster, with secrets-encryption-at-rest flags policies check today.",
  "type": "object",
  "required": ["name", "secrets_encryption_enabled"],
  "properties": {
    "name":                            { "type": "string" },
    "arn":                             { "type": "string" },
    "status":                          { "type": "string" },
    "version":                         { "type": "string" },
    "secrets_encryption_enabled":      { "type": "boolean" },
    "secrets_encryption_kms_key_arn":  { "type": "string" }
  },
  "additionalProperties": true
}
