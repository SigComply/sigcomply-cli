{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.sigcomply.io/evidence_types/guardduty_detector/v1.json",
  "title": "guardduty_detector",
  "version": 1,
  "description": "One AWS GuardDuty detector, with enablement status policies check today.",
  "type": "object",
  "required": ["detector_id", "enabled"],
  "properties": {
    "detector_id":                  { "type": "string" },
    "status":                       { "type": "string" },
    "enabled":                      { "type": "boolean" },
    "service_role":                 { "type": "string" },
    "finding_publishing_frequency": { "type": "string" },
    "created_at":                   { "type": "string", "format": "date-time" },
    "updated_at":                   { "type": "string", "format": "date-time" }
  },
  "additionalProperties": true
}
