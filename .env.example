# =============================================================================
# SigComply CLI - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control (it's in .gitignore).
#
# Only the variables listed here are read from the environment. Behavior
# settings (output format, verbosity, fail-on-violation, storage, region,
# provider scoping) live in `.sigcomply.yaml`, NOT in env vars.
# For full documentation: docs/configuration.md

# -----------------------------------------------------------------------------
# Provider Credentials (REQUIRED - at least one provider)
# -----------------------------------------------------------------------------

# AWS — Uses the standard AWS SDK credential chain.
# Option 1: Static credentials (local development)
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...              # Only if using temporary credentials
# AWS_REGION=us-east-1              # Read by the AWS SDK
#
# Option 2: AWS CLI profile
# AWS_PROFILE=my-profile
#
# Option 3: IAM role / OIDC (CI/CD, ECS, EKS) — no env vars needed.

# GCP — Uses Application Default Credentials (ADC).
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Or run `gcloud auth application-default login` locally.

# Azure — Uses the Azure SDK default credential chain (az login, managed
# identity, or AZURE_* service-principal vars read by the SDK).

# GitHub — Required only if checking GitHub resources.
# GITHUB_TOKEN=ghp_...               # Personal access token or GitHub App token

# GitLab — Required only if checking GitLab resources.
# GITLAB_TOKEN=glpat-...             # Personal or project access token

# Okta — Required only if checking Okta resources.
# OKTA_API_TOKEN=00...               # Okta API token (org URL is set in .sigcomply.yaml)

# -----------------------------------------------------------------------------
# SigComply Settings (OPTIONAL)
# -----------------------------------------------------------------------------

# Framework for `init` and `evidence catalog` only (default: soc2).
# `check` ignores this — it reads `framework:` from `.sigcomply.yaml`.
# SIGCOMPLY_FRAMEWORK=soc2            # Options: soc2, iso27001

# -----------------------------------------------------------------------------
# SigComply Cloud (OPTIONAL — paid tier)
# -----------------------------------------------------------------------------

# Cloud submission uses OIDC tokens auto-detected in CI (GitHub Actions, GitLab CI).
# No API token needed.
