          "type": "string"
        },
        "kmsKeyVersionName": {
          "type": "string",
          "readOnly": true
        },
        "serviceAccountId": {
          "readOnly": true,
          "type": "string"
        },
        "name": {
          "readOnly": true,
          "type": "string"
        }
      },
      "id": "CmekSettings",
      "type": "object"
    },
    "IndexConfig": {
      "properties": {
        "type": {
          "enum": [
            "INDEX_TYPE_UNSPECIFIED",
            "INDEX_TYPE_STRING",
            "INDEX_TYPE_INTEGER"
          ],
          "type": "string",
          "enumDescriptions": [
            "The index's type is unspecified.",
            "The index is a string-type index.",
            "The index is a integer-type index."
          ]
        },
        "createTime": {
          "format": "google-datetime",
          "type": "string",
          "readOnly": true
        },
        "fieldPath": {
          "type": "string"
        }
      },
      "id": "IndexConfig",
      "type": "object"
    },
    "LogBucket": {
      "id": "LogBucket",
      "type": "object",
      "properties": {
