{
  "discoveryVersion": "v1",
  "name": "compute",
  "version": "v1",
  "x-slice": "response-schema closure consumed by internal/sources/gcp",
  "schemas": {
    "AcceleratorConfig": {
      "type": "object",
      "id": "AcceleratorConfig",
      "properties": {
        "acceleratorType": {
          "type": "string"
        },
        "acceleratorCount": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "AccessConfig": {
      "type": "object",
      "id": "AccessConfig",
      "properties": {
        "networkTier": {
          "enumDescriptions": [
            "Public internet quality with fixed bandwidth.",
            "High quality, Google-grade network tier, support for all networking\nproducts.",
            "Public internet quality, only limited support for other networking\nproducts.",
            "(Output only) Temporary tier for FIXED_STANDARD when fixed standard tier\nis expired or not configured."
          ],
          "type": "string",
          "enum": [
            "FIXED_STANDARD",
            "PREMIUM",
            "STANDARD",
            "STANDARD_OVERRIDES_FIXED_STANDARD"
          ]
        },
        "externalIpv6": {
          "type": "string"
        },
        "setPublicPtr": {
          "type": "boolean"
        },
        "kind": {
          "default": "compute#accessConfig",
          "readOnly": true,
          "type": "string"
        },
        "publicPtrDomainName": {
          "type": "string"
        },
        "natIP": {
          "type": "string"
        },
        "externalIpv6PrefixLength": {
          "type": "integer",
          "format": "int32"
        },
        "type": {
          "enumDescriptions": [
            "",
            ""
          ],
          "type": "string",
          "enum": [
            "DIRECT_IPV6",
            "ONE_TO_ONE_NAT"
          ]
        },
        "name": {
          "type": "string"
        },
        "securityPolicy": {
          "type": "string"
        }
      }
    },
    "AdvancedMachineFeatures": {
      "id": "AdvancedMachineFeatures",
      "properties": {
        "visibleCoreCount": {
          "format": "int32",
          "type": "integer"
        },
        "enableNestedVirtualization": {
          "type": "boolean"
        },
        "threadsPerCore": {
          "format": "int32",
          "type": "integer"
        },
        "turboMode": {
          "type": "string"
        },
        "enableUefiNetworking": {
          "type": "boolean"
        },
        "performanceMonitoringUnit": {
          "enumDescriptions": [
            "Architecturally defined non-LLC events.",
            "Most documented core/L2 and LLC events.",
            "",
            "Most documented core/L2 events."
          ],
          "type": "string",
          "enum": [
            "ARCHITECTURAL",
            "ENHANCED",
            "PERFORMANCE_MONITORING_UNIT_UNSPECIFIED",
            "STANDARD"
          ]
        }
      },
      "type": "object"
    },
    "AliasIpRange": {
      "id": "AliasIpRange",
      "properties": {
        "ipCidrRange": {
          "type": "string"
        },
        "subnetworkRangeName": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "AttachedDisk": {
      "id": "AttachedDisk",
      "properties": {
        "diskSizeGb": {
          "format": "int64",
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": [
            "READ_ONLY",
            "READ_WRITE"
          ],
          "enumDescriptions": [
            "Attaches this disk in read-only mode. Multiple virtual machines can use\na disk in read-only mode at a time.",
            "*[Default]* Attaches this disk in read-write mode. Only one\nvirtual machine at a time can be attached to a disk in read-write mode."
          ]
        },
        "licenses": {
          "type": "array",
          "readOnly": true,
          "items": {
            "type": "string"
          }
        },
        "type": {
          "enumDescriptions": [
            "",
            ""
          ],
          "type": "string",
          "enum": [
            "PERSISTENT",
            "SCRATCH"
          ]
        },
        "savedState": {
          "readOnly": true,
          "enum": [
            "DISK_SAVED_STATE_UNSPECIFIED",
            "PRESERVED"
          ],
          "enumDescriptions": [
            "*[Default]* Disk state has not been preserved.",
            "Disk state has been preserved."
          ],
          "type": "string"
        },
        "boot": {
          "type": "boolean"
        },
        "forceAttach": {
          "type": "boolean"
        },
        "source": {
          "type": "string"
        },
        "deviceName": {
          "type": "string"
        },
        "kind": {
          "default": "compute#attachedDisk",
          "readOnly": true,
          "type": "string"
        },
        "autoDelete": {
          "type": "boolean"
        },
        "interface": {
          "enumDescriptions": [
            "",
            ""
          ],
          "type": "string",
          "enum": [
            "NVME",
            "SCSI"
          ]
        },
        "architecture": {
          "type": "string",
          "enum": [
            "ARCHITECTURE_UNSPECIFIED",
            "ARM64",
            "X86_64"
          ],
          "enumDescriptions": [
            "Default value indicating Architecture is not set.",
            "Machines with architecture ARM64",
            "Machines with architecture X86_64"
          ],
          "readOnly": true
        },
        "guestOsFeatures": {
          "type": "array",
          "items": {
            "$ref": "GuestOsFeature"
          }
        },
        "index": {
          "type": "integer",
          "readOnly": true,
          "format": "int32"
        },
        "diskEncryptionKey": {
          "$ref": "CustomerEncryptionKey"
        },
        "shieldedInstanceInitialState": {
          "readOnly": true,
          "$ref": "InitialStateConfig"
        },
        "initializeParams": {
          "$ref": "AttachedDiskInitializeParams"
        }
      },
      "type": "object"
    },
    "AttachedDiskInitializeParams": {
      "type": "object",
      "id": "AttachedDiskInitializeParams",
      "properties": {
        "provisionedIops": {
          "type": "string",
          "format": "int64"
        },
        "sourceImageEncryptionKey": {
          "$ref": "CustomerEncryptionKey"
        },
        "replicaZones": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "architecture": {
          "enumDescriptions": [
            "Default value indicating Architecture is not set.",
            "Machines with architecture ARM64",
            "Machines with architecture X86_64"
          ],
          "type": "string",
          "enum": [
            "ARCHITECTURE_UNSPECIFIED",
            "ARM64",
            "X86_64"
          ]
        },
        "diskType": {
          "type": "string"
        },
        "storagePool": {
          "type": "string"
        },
        "onUpdateAction": {
          "type": "string",
          "enum": [
            "RECREATE_DISK",
            "RECREATE_DISK_IF_SOURCE_CHANGED",
            "USE_EXISTING_DISK"
          ],
          "enumDescriptions": [
            "Always recreate the disk.",
            "Recreate the disk if source (image, snapshot) of this disk is different\nfrom source of existing disk.",
            "Use the existing disk, this is the default behaviour."
          ]
        },
        "licenses": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "diskSizeGb": {
          "type": "string",
          "format": "int64"
        },
        "enableConfidentialCompute": {
          "type": "boolean"
        },
        "sourceSnapshot": {
          "type": "string"
        },
        "resourcePolicies": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "resourceManagerTags": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "diskName": {
          "type": "string"
        },
        "sourceSnapshotEncryptionKey": {
          "$ref": "CustomerEncryptionKey"
        },
        "provisionedThroughput": {
          "format": "int64",
          "type": "string"
        },
        "sourceImage": {
          "type": "string"
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "ConfidentialInstanceConfig": {
      "id": "ConfidentialInstanceConfig",
      "properties": {
        "enableConfidentialCompute": {
          "type": "boolean"
        },
        "confidentialInstanceType": {
          "enumDescriptions": [
            "Arm Confidential Compute Architecture.",
            "No type specified. Do not use this value.",
            "AMD Secure Encrypted Virtualization.",
            "AMD Secure Encrypted Virtualization - Secure Nested Paging.",
            "Intel Trust Domain eXtension."
          ],
          "type": "string",
          "enum": [
            "CCA",
            "CONFIDENTIAL_INSTANCE_TYPE_UNSPECIFIED",
            "SEV",
            "SEV_SNP",
            "TDX"
          ]
        }
      },
      "type": "object"
    },
    "CustomerEncryptionKey": {
      "id": "CustomerEncryptionKey",
      "properties": {
        "rawKey": {
          "type": "string"
        },
        "rsaEncryptedKey": {
          "type": "string"
        },
        "kmsKeyName": {
          "type": "string"
        },
        "sha256": {
          "type": "string"
        },
        "kmsKeyServiceAccount": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "DisplayDevice": {
      "type": "object",
      "id": "DisplayDevice",
      "properties": {
        "enableDisplay": {
          "type": "boolean"
        }
      }
    },
    "Duration": {
      "id": "Duration",
      "properties": {
        "seconds": {
          "format": "int64",
          "type": "string"
        },
        "nanos": {
          "type": "integer",
          "format": "int32"
        }
      },
      "type": "object"
    },
    "FileContentBuffer": {
      "id": "FileContentBuffer",
      "properties": {
        "content": {
          "format": "byte",
          "type": "string"
        },
        "fileType": {
          "enumDescriptions": [
            "",
            "",
            ""
          ],
          "type": "string",
          "enum": [
            "BIN",
            "UNDEFINED",
            "X509"
          ]
        }
      },
      "type": "object"
    },
    "GuestOsFeature": {
      "type": "object",
      "id": "GuestOsFeature",
      "properties": {
        "type": {
          "enumDescriptions": [
            "",
            "",
            "",
            "",
            "",
            "",
            "",
            "",
            "",
            "",
            "",
            "",
            "",
            "",
            "",
            ""
          ],
          "type": "string",
          "enum": [
            "BARE_METAL_LINUX_COMPATIBLE",
            "CCA_CAPABLE",
            "FEATURE_TYPE_UNSPECIFIED",
            "GVNIC",
            "IDPF",
            "MULTI_IP_SUBNET",
            "SECURE_BOOT",
            "SEV_CAPABLE",
            "SEV_LIVE_MIGRATABLE",
            "SEV_LIVE_MIGRATABLE_V2",
            "SEV_SNP_CAPABLE",
            "SNP_SVSM_CAPABLE",
            "TDX_CAPABLE",
            "UEFI_COMPATIBLE",
            "VIRTIO_SCSI_MULTIQUEUE",
            "WINDOWS"
