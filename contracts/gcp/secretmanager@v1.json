{
  "discoveryVersion": "v1",
  "name": "secretmanager",
  "version": "v1",
  "x-slice": "response-schema closure consumed by internal/sources/gcp",
  "schemas": {
    "Automatic": {
      "id": "Automatic",
      "type": "object",
      "properties": {
        "customerManagedEncryption": {
          "$ref": "CustomerManagedEncryption"
        }
      }
    },
    "AutomaticStatus": {
      "id": "AutomaticStatus",
      "type": "object",
      "properties": {
        "customerManagedEncryption": {
          "readOnly": true,
          "$ref": "CustomerManagedEncryptionStatus"
        }
      }
    },
    "CustomerManagedEncryption": {
      "id": "CustomerManagedEncryption",
      "type": "object",
      "properties": {
        "kmsKeyName": {
          "type": "string"
        }
      }
    },
    "CustomerManagedEncryptionStatus": {
      "id": "CustomerManagedEncryptionStatus",
      "type": "object",
      "properties": {
        "kmsKeyVersionName": {
          "type": "string"
        }
      }
    },
    "Replica": {
      "id": "Replica",
      "type": "object",
      "properties": {
        "location": {
          "type": "string"
        },
        "customerManagedEncryption": {
          "$ref": "CustomerManagedEncryption"
        }
      }
    },
    "ReplicaStatus": {
      "id": "ReplicaStatus",
      "type": "object",
      "properties": {
        "location": {
          "readOnly": true,
          "type": "string"
        },
        "customerManagedEncryption": {
          "readOnly": true,
          "$ref": "CustomerManagedEncryptionStatus"
        }
      }
    },
    "Replication": {
      "id": "Replication",
      "type": "object",
      "properties": {
        "automatic": {
          "$ref": "Automatic"
        },
        "userManaged": {
          "$ref": "UserManaged"
        }
      }
    },
    "ReplicationStatus": {
      "id": "ReplicationStatus",
      "type": "object",
      "properties": {
        "automatic": {
          "$ref": "AutomaticStatus"
        },
        "userManaged": {
          "$ref": "UserManagedStatus"
        }
      }
    },
    "Rotation": {
      "id": "Rotation",
      "type": "object",
      "properties": {
        "nextRotationTime": {
          "type": "string",
          "format": "google-datetime"
        },
        "rotationPeriod": {
          "type": "string",
          "format": "google-duration"
        }
      }
    },
    "Secret": {
      "id": "Secret",
      "type": "object",
      "properties": {
        "name": {
          "readOnly": true,
          "type": "string"
        },
        "replication": {
          "$ref": "Replication"
        },
        "createTime": {
          "readOnly": true,
          "type": "string",
          "format": "google-datetime"
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "topics": {
          "type": "array",
          "items": {
            "$ref": "Topic"
          }
        },
        "expireTime": {
          "type": "string",
          "format": "google-datetime"
        },
        "ttl": {
          "type": "string",
          "format": "google-duration"
        },
        "etag": {
          "type": "string"
        },
        "rotation": {
          "$ref": "Rotation"
        },
        "versionAliases": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "format": "int64"
          }
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "versionDestroyTtl": {
          "type": "string",
          "format": "google-duration"
        },
        "customerManagedEncryption": {
          "$ref": "CustomerManagedEncryption"
        },
        "tags": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "SecretVersion": {
      "id": "SecretVersion",
      "type": "object",
      "properties": {
        "name": {
          "readOnly": true,
          "type": "string"
        },
        "createTime": {
          "readOnly": true,
          "type": "string",
          "format": "google-datetime"
        },
        "destroyTime": {
          "readOnly": true,
          "type": "string",
          "format": "google-datetime"
        },
        "state": {
          "readOnly": true,
          "type": "string",
          "enumDescriptions": [
            "Not specified. This value is unused and invalid.",
            "The SecretVersion may be accessed.",
            "The SecretVersion may not be accessed, but the secret data is still available and can be placed back into the ENABLED state.",
            "The SecretVersion is destroyed and the secret data is no longer stored. A version may not leave this state once entered."
          ],
          "enum": [
            "STATE_UNSPECIFIED",
            "ENABLED",
            "DISABLED",
            "DESTROYED"
          ]
        },
        "replicationStatus": {
          "$ref": "ReplicationStatus"
        },
        "etag": {
          "readOnly": true,
          "type": "string"
        },
        "clientSpecifiedPayloadChecksum": {
          "readOnly": true,
          "type": "boolean"
        },
        "scheduledDestroyTime": {
          "readOnly": true,
          "type": "string",
          "format": "google-datetime"
        },
        "customerManagedEncryption": {
          "readOnly": true,
          "$ref": "CustomerManagedEncryptionStatus"
        }
      }
    },
    "Topic": {
      "id": "Topic",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        }
      }
    },
    "UserManaged": {
      "id": "UserManaged",
      "type": "object",
      "properties": {
        "replicas": {
          "type": "array",
          "items": {
            "$ref": "Replica"
          }
        }
      }
    },
    "UserManagedStatus": {
      "id": "UserManagedStatus",
      "type": "object",
      "properties": {
        "replicas": {
          "readOnly": true,
          "type": "array",
          "items": {
            "$ref": "ReplicaStatus"
          }
        }
      }
    }
  }
}